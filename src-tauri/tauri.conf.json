{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EntrevistAI",
  "version": "0.1.0",
  "identifier": "com.entrevistai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EntrevistAI",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
