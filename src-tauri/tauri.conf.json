{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EntrevistAI",
  "version": "0.1.0",
  "identifier": "com.entrevistai.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EntrevistAI",
        "width": 960,
        "height": 640,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "category": "Productivity"
  }
}
